{
    "name": "mcp-searxng",
    "version": "1.0.3",
    "mcpName": "io.github.tterrasson/mcp-searxng",
    "description": "MCP server for SearXNG integration",
    "license": "MIT",
    "author": "tterrasson (https://github.com/tterrasson)",
    "homepage": "https://github.com/tterrasson/mcp-searxng",
    "bugs": "https://github.com/tterrasson/mcp-searxng/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/tterrasson/mcp-searxng"
    },
    "keywords": [
        "mcp",
        "modelcontextprotocol",
        "searxng",
        "search",
        "web-search",
        "claude",
        "ai",
        "pagination",
        "smithery",
        "url-reader"
    ],
    "type": "module",
    "bin": {
        "mcp-searxng": "dist/index.js"
    },
    "main": "dist/index.js",
    "files": [
        "dist"
    ],
    "engines": {
        "bun": ">=1.0"
    },
    "scripts": {
        "build": "bun build src/index.ts --outfile dist/index.js --target bun",
        "typecheck": "tsc --noEmit",
        "watch": "bun --watch src/index.ts",
        "test": "bun test tests --reporter=dots --only-failures",
        "test:coverage": "bun test --coverage tests",
        "bootstrap": "bun install && bun run build",
        "inspector": "DANGEROUSLY_OMIT_AUTH=true bunx @modelcontextprotocol/inspector bun dist/index.js",
        "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "1.29.0",
        "@mozilla/readability": "^0.6.0",
        "linkedom": "^0.18.12",
        "turndown": "^7.2.4"
    },
    "devDependencies": {
        "bun-types": "latest",
        "@types/mozilla__readability": "^0.4.2",
        "@types/turndown": "^5.0.6",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^10.1.0",
        "typescript": "^5.8.3"
    }
}
